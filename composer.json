{
  "name": "luanoldcode/forge_fpdf",
  "homepage": "https://github.com/LuanOldCode/Forge_Fpdf",
  "description": "Forge_Fpdf Composer Wrapper",
  "keywords": [
    "Forge",
    "fpdf",
    "pdf",
    "wrapper"
  ],
  "license": "Apache License 2.0",
  "type": "library",
  "authors": [
    {
      "name": "Luan Costa",
      "email": "luangotardodeveloper@gmail.com"
    }
  ],
  "require": {
    "php": ">=5.6.0"
  },
  "config": {
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "Fpdf\\": "src/Fpdf",
      "Forge_Fpdf\\": "LuanOldCode\\Forge_Fpdf"
    }
  },
  "archive": {
    "exclude": [
      "original"
    ]
  },
  "extra": {
    "laravel": {
      "aliases": {
        "FPDF": "Fpdf\\Fpdf",
        "Forge_Fpdf": "LuanOldCode\\Forge_Fpdf"
      }
    }
  }
}
